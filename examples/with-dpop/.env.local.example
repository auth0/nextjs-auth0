SRC_DIR=~/src

AUTH0_DOMAIN=your-auth0-domain.auth0.com
AUTH0_CLIENT_ID='your-client-id'
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_ISSUER_BASE_URL='https://your-auth0-domain.auth0.com'
AUTH0_AUDIENCE='https://your-auth0-domain.auth0.com/api/v2/'

AUTH0_SECRET=a-long-random-value-used-to-encrypt-the-session-cookie
APP_BASE_URL=http://localhost:3000
AUTH0_SCOPE='openid profile email offline_access'

# New Cookie Options from PR #2059
# AUTH0_COOKIE_DOMAIN='.example.com' # Set cookie for subdomains (Commented out for localhost)
# AUTH0_COOKIE_PATH='/app'          # Limit cookie to /app path (Commented out for default '/')
# AUTH0_COOKIE_TRANSIENT=true      # Make cookie persistent (expires based on session lifetime)
# AUTH0_COOKIE_HTTP_ONLY=false       # Recommended for security
# AUTH0_COOKIE_SECURE=false         # Set to true for HTTPS environments
# AUTH0_COOKIE_SAME_SITE='Lax'      # Recommended default

# DPoP Configuration (optional)
# Set USE_DPOP=true to enable DPoP demonstration
USE_DPOP=false

# Optional: Provide your own DPoP key pair (PEM format)
# If not provided, a key pair will be generated automatically when USE_DPOP=true
# AUTH0_DPOP_PUBLIC_KEY='-----BEGIN PUBLIC KEY-----
MFkwEwYHKoZIzj0CAQYIKoZIzj0DAQcDQgAE...
-----END PUBLIC KEY-----'
# AUTH0_DPOP_PRIVATE_KEY='-----BEGIN PRIVATE KEY-----
MIGHAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBG0wawIBAQ...
-----END PRIVATE KEY-----'

EMAIL=your-test-email@example.com
PASSWORD=your-test-password

# DPoP Configuration (optional)
# Set USE_DPOP=true to enable DPoP demonstration
USE_DPOP=false

# Optional: Provide your own DPoP key pair (PEM format)
# If not provided, a key pair will be generated automatically when USE_DPOP=true
# AUTH0_DPOP_PUBLIC_KEY='-----BEGIN PUBLIC KEY-----\nMFkwEwYHKoZIzj0CAQYIKoZIzj0DAQcDQgAE...\n-----END PUBLIC KEY-----'
# AUTH0_DPOP_PRIVATE_KEY='-----BEGIN PRIVATE KEY-----\nMIGHAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBG0wawIBAQ...\n-----END PRIVATE KEY-----'
