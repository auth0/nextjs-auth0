# ============================================================================
# Auth0 Tenant Configuration
# ============================================================================

# Your custom domain with mTLS enabled (REQUIRED for production)
# Example: auth.yourcompany.com
AUTH0_DOMAIN=your-custom-domain.auth0.com

# Application Client ID
AUTH0_CLIENT_ID=your-client-id

# Session encryption secret (generate with: openssl rand -hex 32)
AUTH0_SECRET=please-generate-a-secret-with-openssl-rand-hex-32

# Application base URL
APP_BASE_URL=http://localhost:3000

# ============================================================================
# mTLS Certificate Paths
# ============================================================================

# Path to client certificate PEM file
MTLS_CLIENT_CERT_PATH=./certs/client.crt

# Path to client private key PEM file
MTLS_CLIENT_KEY_PATH=./certs/client.key

# Optional: CA certificate bundle (if needed for verification)
# MTLS_CA_CERT_PATH=./certs/ca.crt

# ============================================================================
# Optional Configuration
# ============================================================================

# API audience (if calling a resource server API)
# AUTH0_AUDIENCE=https://api.example.com
# ============================================================================
# Auth0 Tenant Configuration
# ============================================================================

# ⚠️  CURRENT ISSUE: This domain does NOT have mtls_endpoint_aliases configured.
# This means:
#   - Browser login will fail (tries to use mTLS domain for /authorize)
#   - Only server-to-server tests work (test-vivaldi-m2m.mjs)
#
# FOR PRODUCTION:
#   - Use a custom domain with mTLS properly configured
#   - Discovery document must show mtls_endpoint_aliases
#   - Then browser login works: /authorize = regular HTTPS, /oauth/token = mTLS
#
# TO TEST FULL FLOW:
#   - Set up custom domain in Auth0 Dashboard
#   - Enable mTLS on that domain
#   - Update AUTH0_DOMAIN below to your custom domain
#   - See CUSTOM_DOMAIN_SETUP.md for instructions

AUTH0_DOMAIN=login0.local.dev.auth0.com
AUTH0_CLIENT_ID=3S8lv5XPH0OFPqxzR4ecPKoxo2AZcDBK

# For Vivaldi (no mtls_endpoint_aliases): Use client_secret
# For Production mTLS: Remove this - certificate authenticates instead
AUTH0_CLIENT_SECRET=CkIKIBJicIgJeqW2SNuF2196+Jev3KNe3SaTa0NDoX9vp9SAEgziYitJfbWNJgMdPjIaECIet67nbkaOB3OLjNr7DcgSYgpA622hqhqLIYQIc1tO6hGWspX116Q4cAu3l92/J8uRQccjfOodgvHOejrW/8Uhxp/ZYRD9RffSFo3cIyM/x0FtLBIMAquJyq7KdRmoS+KsGhCBWCivqyuR/gU54Gh4jvjGGhAFGdU6c+1B5LP9Jx8UxjIZ

AUTH0_SECRET=aab1217fa82503f58b054967ef5c4d4b05c6ab70753923a96543b45240ce8421
APP_BASE_URL=http://localhost:3000
AUTH0_BASE_URL=http://localhost:3000

# Cookie configuration for localhost (HTTP)
AUTH0_COOKIE_SECURE=false
AUTH0_COOKIE_SAMESITE=lax
AUTH0_COOKIE_DOMAIN=localhost

# Path to the PEM files for the mTLS client certificate.
# These are used in lib/auth0.ts to create the undici TLS agent.
MTLS_CLIENT_CERT_PATH=./certs/client.crt
MTLS_CLIENT_KEY_PATH=./certs/client.key

# Optional: CA certificate for mutual verification (if your Auth0 tenant requires it)
# MTLS_CA_CERT_PATH=./certs/ca.crt

# Optional: API audience for token requests
# AUTH0_AUDIENCE=https://api.example.com

